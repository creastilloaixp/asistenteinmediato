# ===========================================
# AutoCobro API - Environment Variables
# ===========================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/autocobro?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# Mercado Pago (México)
MERCADOPAGO_ACCESS_TOKEN="TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
MERCADOPAGO_WEBHOOK_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# Kiosk Settings
KIOSK_API_TIMEOUT=30000
